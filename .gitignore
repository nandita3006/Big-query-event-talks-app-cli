# pyenv
#   For a list of profiles see: https://github.com/pyenv/pyenv#environment-variables
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you are well sync'd, it is fine.
#   But if you do check lock file, please do ignore these:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   But if you choose not to, ignore it here:
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#pdm.lock
#   pdm local configuration
.pdm-python
.pdm-db/

